POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# Dev-only secret. Must be >= 32 chars and NOT the placeholder
# "change-me-in-production" (rejected at startup). Regenerate for production.
PCA_AUTH_JWT_SECRET=dev-only-replace-in-prod-7Hk2wQpL3xRnF8tEsCvBmAyZ

# When compose-up is launched alongside the jaeger service the server should
# point at jaeger:4317. Leave empty to disable OTLP export (tracing is dropped
# but the app still functions).
PCA_TELEMETRY_OTLP_ENDPOINT=jaeger:4317

# Static bearer token for Prometheus scrape jobs. MUST match the bearer in
# prometheus.yml (we hard-code it there since Prom doesn't interpolate env).
# CHANGE THIS IN PRODUCTION.
PCA_OBSERVABILITY_METRICS_TOKEN=dev-scrape-token-change-me

PCA_OBSERVABILITY_LOG_FORMAT=json
PCA_OBSERVABILITY_LOG_LEVEL=info
