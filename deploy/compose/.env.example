POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app

# Dev-only secret. Must be >= 32 chars and NOT the placeholder
# "change-me-in-production" (rejected at startup). Regenerate for production.
PCA_AUTH_JWT_SECRET=dev-only-replace-in-prod-7Hk2wQpL3xRnF8tEsCvBmAyZ

# When compose-up is launched alongside the jaeger service the server should
# point at jaeger:4317. Leave empty to disable OTLP export (tracing is dropped
# but the app still functions).
PCA_TELEMETRY_OTLP_ENDPOINT=jaeger:4317

# Static bearer token for Prometheus scrape jobs. MUST match the bearer in
# prometheus.yml (we hard-code it there since Prom doesn't interpolate env).
# CHANGE THIS IN PRODUCTION.
PCA_OBSERVABILITY_METRICS_TOKEN=dev-scrape-token-change-me

PCA_OBSERVABILITY_LOG_FORMAT=json
PCA_OBSERVABILITY_LOG_LEVEL=info

# Alibaba Cloud Model Studio (百炼) API Key — OpenAI-compatible mode.
# Create at: https://bailian.console.aliyun.com/ → API-KEY
# Required for chat model dashscope:qwen3.6-plus (see migration 0012).
DASHSCOPE_API_KEY=

# Memory vector search (1536-d; matches migration vector(1536)).
# E2E / offline: PCA_MEMORY_EMBEDDING_MODEL=default-mock:text
PCA_MEMORY_EMBEDDING_MODEL=dashscope:text-embedding-v4

# Slice 13 quota (optional overrides; compose defaults sandbox cap to 1 for E2E).
# PCA_QUOTA_LLM_TOKENS_PER_DAY=200000
# PCA_QUOTA_SANDBOX_MAX_ACTIVE=1
# PCA_QUOTA_TOOL_INVOKE_PER_MINUTE=120
# PCA_RATE_LIMIT_PER_MINUTE=600

# Slice 15 OIDC (E2E uses mock-oidc on :8082)
OIDC_CLIENT_SECRET=e2e-oidc-secret-change-me
# PCA_AUTH_OIDC_ENABLED=true
# PCA_AUTH_OIDC_REDIRECT_URL=http://localhost:8080/auth/oidc/callback

# Slice 21b external MCP manager. enabled=true wires the boot republish and
# heartbeat loop; admin endpoints are mounted in either mode (503 when off).
# PCA_MCP_ENABLED=true
# PCA_MCP_HEARTBEAT_INTERVAL=60s
# PCA_MCP_INVOKE_TIMEOUT=30s
# PCA_MCP_LIST_TOOLS_TIMEOUT=10s
