# Copy to deploy/compose/.env (or a secrets manager) — never commit real tokens.
#
# Slack Bot Token (xoxb-...) from https://api.slack.com/apps
# Scopes (minimum for notify workflows): chat:write, channels:read
SLACK_BOT_TOKEN=xoxb-replace-me

# Protects the MCP HTTP endpoint (maps to PCA MCP auth_type=bearer).
SLACK_MCP_API_KEY=replace-with-long-random-secret

# Optional: "true" or comma-separated channel IDs (C...) to allow posting
SLACK_MCP_ADD_MESSAGE_TOOL=true
